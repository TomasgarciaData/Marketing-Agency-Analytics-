    "# Client registry for the silver/gold pipeline.\n",
    "# Each entry defines the client slug, display name, lakehouse schema and active data sources.\n",
    "# Add a new client here to include it in the pipeline run.\n",
    "\n",
    "CLIENTES = {\n",
    "    \"<client_slug>\": {\n",
    "        \"nombre\": \"<Client Display Name>\",\n",
    "        \"schema\": \"<lakehouse_schema>\",\n",
    "        \"industria\": \"<industry>\",\n",
    "        \"fuentes\": {\n",
    "            \"meta\": {\"activo\": True},\n",
    "            \"shopify\": {\"activo\": True},\n",
    "            \"google_ads\": {\"activo\": False},\n",
    "            \"tiktok\": {\"activo\": False}\n",
    "        }\n",
    "    },\n",
    "    \"<client_slug_2>\": {\n",
    "        \"nombre\": \"<Client Display Name>\",\n",
    "        \"schema\": \"<lakehouse_schema>\",\n",
    "        \"fuentes\": {\n",
    "            \"meta\": {\"activo\": True},\n",
