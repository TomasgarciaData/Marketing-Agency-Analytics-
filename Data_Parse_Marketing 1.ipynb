    "# Unified schemas for e-commerce data across all platforms (Shopify, Tiendanube).\n",
    "\n",
    "# Order lines — one row per product per order.\n",
    "ecommerce_orders_schema = StructType([\n",
    "    StructField(\"platform\", StringType()),\n",
    "    StructField(\"order_id\", StringType()),\n",
    "    StructField(\"product_id\", StringType()),\n",
    "    StructField(\"product_title\", StringType()),\n",
    "    StructField(\"customer_email\", StringType()),\n",
    "    StructField(\"created_at\", StringType()),\n",
    "    StructField(\"unit_price\", DoubleType()),\n",
    "    StructField(\"line_total\", DoubleType()),\n",
    "    StructField(\"total_discount\", DoubleType()),\n",
    "    StructField(\"currency\", StringType()),\n",
    "    StructField(\"quantity\", IntegerType()),\n",
    "    StructField(\"financial_status\", StringType()),\n",
    "    StructField(\"fulfillment_status\", StringType()),\n",
    "    StructField(\"items_count\", IntegerType())\n",
    "])\n",
    "\n",
    "# Product catalog with pricing and inventory.\n",
    "ecommerce_products_schema = StructType([\n",
    "    StructField(\"platform\", StringType()),\n",
    "    StructField(\"product_id\", StringType()),\n",
    "    StructField(\"title\", StringType()),\n",
    "    StructField(\"product_type\", StringType()),\n",
    "    StructField(\"vendor\", StringType()),\n",
