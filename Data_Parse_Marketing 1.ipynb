    "def parse_meta_ads(raw_data):\n",
    "    \"\"\"\n",
    "    Parses raw Meta Ads API response into a list of tuples.\n",
    "    Extracts ad-level metrics and unpacks action types (purchases, \n",
    "    link clicks, landing page views, checkouts) from the actions array.\n",
    "    \"\"\"\n",
    "    rows = []\n",
    "    for a in raw_data:\n",
    "        purchases = 0\n",
    "        link_clicks = 0\n",
    "        landing_views = 0\n",
    "        checkouts = 0\n",
    "        for action in a.get(\"actions\", []):\n",
    "            if action[\"action_type\"] == \"purchase\":\n",
    "                purchases = int(action[\"value\"])\n",
    "            elif action[\"action_type\"] == \"link_click\":\n",
    "                link_clicks = int(action[\"value\"])\n",
    "            elif action[\"action_type\"] == \"landing_page_view\":\n",
    "                landing_views = int(action[\"value\"])\n",
    "            elif action[\"action_type\"] in (\"omni_initiated_checkout\", \"initiated_checkout\"):\n",
    "                checkouts = int(action[\"value\"])\n",
    "        rows.append((\n",
    "            str(a.get(\"date_start\", \"\")),\n",
    "            \"meta\",\n",
    "            str(a.get(\"campaign_name\", \"\")),\n",
    "            str(a.get(\"adset_name\", \"\")),\n",
    "            str(a.get(\"ad_name\", \"\")),\n",
    "            int(a.get(\"impressions\", 0)),\n",
    "            int(a.get(\"reach\", 0)),\n",
    "            int(a.get(\"clicks\", 0)),\n",
    "            float(a.get(\"spend\", 0)),\n",
    "            link_clicks,\n",
    "            landing_views,\n",
    "            checkouts,\n",
    "            purchases\n",
    "        ))\n",
    "    return rows"
   ],
