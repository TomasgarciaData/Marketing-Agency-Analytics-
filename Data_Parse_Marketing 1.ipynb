    "def upsert_table(new_df, table_name, merge_keys, schema_name):\n",
    "    \"\"\"\n",
    "    Upserts a Delta table using the provided merge keys.\n",
    "    If the table already exists, merges new data into it (update on match, insert if new).\n",
    "    If it doesn't exist, creates it — falling back to overwrite if creation fails.\n",
    "    \"\"\"\n",
    "    full_table_name = schema_name + \".\" + table_name\n",
    "    table_path = \"Tables/\" + schema_name + \"/\" + table_name\n",
    "    \n",
    "    if DeltaTable.isDeltaTable(spark, table_path):\n",
    "        delta_table = DeltaTable.forPath(spark, table_path)\n",
    "        condition = \" AND \".join([\"old.\" + k + \" = new.\" + k for k in merge_keys])\n",
    "        delta_table.alias(\"old\").merge(\n",
    "            new_df.alias(\"new\"),\n",
    "            condition\n",
    "        ).whenMatchedUpdateAll().whenNotMatchedInsertAll().execute()\n",
    "        print(\"[Merge] \" + full_table_name)\n",
    "    else:\n",
    "        try:\n",
    "            spark.sql(\"CREATE SCHEMA IF NOT EXISTS \" + schema_name)\n",
    "            new_df.write.format(\"delta\").saveAsTable(full_table_name)\n",
    "            print(\"[Nuevo] \" + full_table_name)\n",
    "        except:\n",
    "            new_df.write.format(\"delta\").mode(\"overwrite\").saveAsTable(full_table_name)\n",
    "            print(\"[Recreado] \" + full_table_name)"
   ],
   "outputs": [
