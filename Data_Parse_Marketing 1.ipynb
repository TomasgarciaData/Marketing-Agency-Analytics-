  {
   "cell_type": "code",
   "source": [
    "from pyspark.sql.functions import to_date, substring, col, to_timestamp, date_format, year, month, dayofmonth, dayofweek, explode\n",
    "\n",
    "for client_id, config in CLIENTES.items():\n",
    "    schema = config[\"schema\"]\n",
    "    print(\"\\n\" + \"=\" * 40)\n",
    "    print(\"GOLD: \" + config[\"nombre\"] + \" (schema: \" + schema + \")\")\n",
    "    print(\"=\" * 40)\n",
    "    \n",
    "    # --- Gold Ads ---\n",
    "    # Casts date string to DateType. No time parsing needed — Meta Ads only provides date-level granularity.\n",
    "    try:\n",
    "        ads = spark.table(schema + \".silver_all_ad_insights\")\n",
    "        gold_ads = ads.select(\n",
    "            to_date(\"date\").alias(\"date\"),\n",
    "            col(\"platform\"),\n",
    "            col(\"campaign_name\"),\n",
    "            col(\"adset_name\"),\n",
    "            col(\"ad_name\"),\n",
    "            col(\"impressions\"),\n",
    "            col(\"reach\"),\n",
    "            col(\"clicks\"),\n",
    "            col(\"spend\"),\n",
    "            col(\"link_clicks\"),\n",
    "            col(\"landing_page_views\"),\n",
    "            col(\"checkouts\"),\n",
    "            col(\"conversions\")\n",
    "        )\n",
    "        upsert_table(gold_ads, \"gold_ads\", [\"date\", \"platform\", \"campaign_name\", \"adset_name\", \"ad_name\"], schema)\n",
    "        print(\"  Gold ads: \" + str(gold_ads.count()))\n",
    "    except Exception as e:\n",
    "        print(\"  Gold ads: sin datos (\" + str(e)[:80] + \")\")\n",
    "    \n",
    "    # --- Gold Organic ---\n",
    "    # Splits ISO timestamp into separate date and time columns for easier filtering in reports.\n",
    "    try:\n",
    "        organic = spark.table(schema + \".silver_all_organic\")\n",
    "        ts_organic = to_timestamp(substring(\"created_time\", 1, 19), \"yyyy-MM-dd'T'HH:mm:ss\")\n",
    "        gold_organic = organic.select(\n",
    "            col(\"platform\"),\n",
    "            col(\"post_id\"),\n",
    "            col(\"message\"),\n",
    "            to_date(substring(\"created_time\", 1, 10)).alias(\"post_date\"),\n",
    "            date_format(ts_organic, \"HH:mm:ss\").alias(\"post_time\"),\n",
    "            col(\"permalink_url\"),\n",
    "            col(\"shares\"),\n",
    "            col(\"likes\"),\n",
    "            col(\"comments\"),\n",
    "            col(\"reach\"),\n",
    "            col(\"impressions\")\n",
    "        )\n",
    "        upsert_table(gold_organic, \"gold_organic\", [\"platform\", \"post_id\"], schema)\n",
    "        print(\"  Gold organic: \" + str(gold_organic.count()))\n",
    "    except Exception as e:\n",
    "        print(\"  Gold organic: sin datos (\" + str(e)[:80] + \")\")\n",
    "    \n",
    "    # --- Gold E-commerce Orders ---\n",
    "    # Splits ISO timestamp into separate date and time columns. Merge key includes product_id\n",
    "    # since one order can have multiple line items.\n",
    "    try:\n",
    "        orders = spark.table(schema + \".silver_ecommerce_orders\")\n",
    "        ts_orders = to_timestamp(substring(\"created_at\", 1, 19), \"yyyy-MM-dd'T'HH:mm:ss\")\n",
    "        gold_orders = orders.select(\n",
    "            col(\"platform\"),\n",
    "            col(\"order_id\"),\n",
    "            col(\"product_id\"),\n",
    "            col(\"product_title\"),\n",
    "            col(\"customer_email\"),\n",
    "            to_date(substring(\"created_at\", 1, 10)).alias(\"order_date\"),\n",
    "            date_format(ts_orders, \"HH:mm:ss\").alias(\"order_time\"),\n",
    "            col(\"unit_price\"),\n",
    "            col(\"line_total\"),\n",
    "            col(\"total_discount\"),\n",
    "            col(\"currency\"),\n",
    "            col(\"quantity\"),\n",
    "            col(\"financial_status\"),\n",
    "            col(\"fulfillment_status\"),\n",
    "            col(\"items_count\")\n",
    "        )\n",
    "        upsert_table(gold_orders, \"gold_ecommerce_orders\", [\"platform\", \"order_id\", \"product_id\"], schema)\n",
    "        print(\"  Gold ecommerce orders: \" + str(gold_orders.count()))\n",
    "    except Exception as e:\n",
    "        print(\"  Gold ecommerce orders: sin datos (\" + str(e)[:80] + \")\")\n",
    "    \n",
    "    # --- Gold E-commerce Products ---\n",
    "    # No transformations needed — passes through silver as-is.\n",
    "    try:\n",
    "        products = spark.table(schema + \".silver_ecommerce_products\")\n",
    "        gold_products = products.select(\n",
    "            col(\"platform\"),\n",
    "            col(\"product_id\"),\n",
    "            col(\"title\"),\n",
    "            col(\"product_type\"),\n",
    "            col(\"vendor\"),\n",
    "            col(\"price\"),\n",
    "            col(\"status\"),\n",
    "            col(\"inventory_quantity\")\n",
    "        )\n",
    "        upsert_table(gold_products, \"gold_ecommerce_products\", [\"platform\", \"product_id\"], schema)\n",
    "        print(\"  Gold ecommerce products: \" + str(gold_products.count()))\n",
    "    except Exception as e:\n",
    "        print(\"  Gold ecommerce products: sin datos (\" + str(e)[:80] + \")\")\n",
    "    \n",
    "    # --- Gold E-commerce Customers ---\n",
    "    # No transformations needed — passes through silver as-is.\n",
    "    try:\n",
    "        customers = spark.table(schema + \".silver_ecommerce_customers\")\n",
    "        gold_customers = customers.select(\n",
    "            col(\"platform\"),\n",
    "            col(\"customer_id\"),\n",
    "            col(\"email\"),\n",
    "            col(\"first_name\"),\n",
    "            col(\"last_name\"),\n",
    "            col(\"city\"),\n",
    "            col(\"country\"),\n",
    "            col(\"orders_count\"),\n",
    "            col(\"total_spent\")\n",
    "        )\n",
    "        upsert_table(gold_customers, \"gold_ecommerce_customers\", [\"platform\", \"customer_id\"], schema)\n",
    "        print(\"  Gold ecommerce customers: \" + str(gold_customers.count()))\n",
    "    except Exception as e:\n",
    "        print(\"  Gold ecommerce customers: sin datos (\" + str(e)[:80] + \")\")\n",
    "    \n",
    "    # --- Calendar Table ---\n",
    "    # Generates a date dimension table from 2025 to 2026 with year, month, day and weekday fields.\n",
    "    # Dropped and recreated on each run to stay current.\n",
    "    try:\n",
    "        calendario = spark.sql(\"SELECT explode(sequence(to_date('2025-01-01'), to_date('2026-12-31'), interval 1 day)) as date\")\n",
    "        calendario = calendario.select(\n",
    "            col(\"date\"),\n",
    "            year(\"date\").alias(\"year\"),\n",
    "            month(\"date\").alias(\"month\"),\n",
    "            dayofmonth(\"date\").alias(\"day\"),\n",
    "            dayofweek(\"date\").alias(\"day_of_week\"),\n",
    "            date_format(\"date\", \"MMMM\").alias(\"month_name\"),\n",
    "            date_format(\"date\", \"EEEE\").alias(\"day_name\")\n",
    "        )\n",
    "        spark.sql(\"DROP TABLE IF EXISTS \" + schema + \".calendario\")\n",
    "        calendario.write.format(\"delta\").saveAsTable(schema + \".calendario\")\n",
    "        print(\"  Calendario: \" + str(calendario.count()) + \" dias\")\n",
    "    except Exception as e:\n",
    "        print(\"  Calendario: error (\" + str(e)[:80] + \")\")\n",
    "\n",
    "print(\"\\n=== PROCESO COMPLETO ===\")\n",
    "print(\"\\nCampos de tiempo en Gold:\")\n",
    "print(\"  gold_ads -> date (DateType, sin hora)\")\n",
    "print(\"  gold_organic -> post_date (DateType) + post_time (String '23:16:53')\")\n",
    "print(\"  gold_ecommerce_orders -> order_date (DateType) + order_time (String '14:19:19')\")"
   ],
   "outputs": [
