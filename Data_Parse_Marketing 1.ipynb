   "source": [
    "# Maps each active platform to its bronze path and parser function.\n",
    "# Only platforms marked as active in CLIENTES will be processed.\n",
    "PARSERS_ADS = {\n",
    "    \"meta\": (\"meta/ad_insights\", parse_meta_ads),\n",
    "}\n",
    "\n",
    "PARSERS_ORGANIC = {\n",
    "    \"meta\": (\"meta/organic_posts_enriched\", parse_meta_organic),\n",
    "}\n",
    "\n",
    "PARSERS_ECOMMERCE = {\n",
    "    \"shopify\": {\n",
    "        \"orders\": (\"shopify/orders\", parse_shopify_orders),\n",
    "        \"products\": (\"shopify/products\", parse_shopify_products),\n",
    "        \"customers\": (\"shopify/customers\", parse_shopify_customers)\n",
    "    }\n",
    "}\n",
    "\n",
    "for client_id, config in CLIENTES.items():\n",
    "    schema = config[\"schema\"]\n",
    "    print(\"\\n\" + \"=\" * 40)\n",
    "    print(\"SILVER: \" + config[\"nombre\"] + \" (schema: \" + schema + \")\")\n",
    "    print(\"=\" * 40)\n",
    "    \n",
    "    # --- Silver Ads ---\n",
    "    # Reads bronze ad insights for each active platform, parses and merges into a unified silver table.\n",
    "    all_ad_rows = []\n",
    "    for fuente_id, (bronze_path, parser) in PARSERS_ADS.items():\n",
    "        if not config[\"fuentes\"].get(fuente_id, {}).get(\"activo\", False):\n",
    "            continue\n",
    "        try:\n",
    "            bronze = spark.read.json(\"Files/\" + client_id + \"/bronze/\" + bronze_path)\n",
    "            raw = json.loads(bronze.select(\"raw_data\").collect()[0][0])\n",
    "            if len(raw) > 0:\n",
    "                rows = parser(raw)\n",
    "                all_ad_rows.extend(rows)\n",
    "                print(\"  \" + fuente_id + \" ads: \" + str(len(rows)) + \" registros\")\n",
    "        except Exception as e:\n",
    "            print(\"  \" + fuente_id + \" ads: sin datos (\" + str(e)[:50] + \")\")\n",
    "    \n",
    "    if len(all_ad_rows) > 0:\n",
    "        df_ads = spark.createDataFrame(all_ad_rows, ads_schema)\n",
    "        upsert_table(df_ads, \"silver_all_ad_insights\", [\"date\", \"platform\", \"campaign_name\", \"adset_name\", \"ad_name\"], schema)\n",
    "        print(\"  Silver ads total: \" + str(len(all_ad_rows)))\n",
    "    \n",
    "    # --- Silver Organic ---\n",
    "    # Reads bronze organic posts for each active platform, parses and merges into a unified silver table.\n",
    "    all_organic_rows = []\n",
    "    for fuente_id, (bronze_path, parser) in PARSERS_ORGANIC.items():\n",
    "        if not config[\"fuentes\"].get(fuente_id, {}).get(\"activo\", False):\n",
    "            continue\n",
    "        try:\n",
    "            bronze = spark.read.json(\"Files/\" + client_id + \"/bronze/\" + bronze_path)\n",
    "            raw = json.loads(bronze.select(\"raw_data\").collect()[0][0])\n",
    "            if len(raw) > 0:\n",
    "                rows = parser(raw)\n",
    "                all_organic_rows.extend(rows)\n",
    "                print(\"  \" + fuente_id + \" organic: \" + str(len(rows)) + \" registros\")\n",
    "        except Exception as e:\n",
    "            print(\"  \" + fuente_id + \" organic: sin datos (\" + str(e)[:50] + \")\")\n",
    "    \n",
    "    if len(all_organic_rows) > 0:\n",
    "        df_organic = spark.createDataFrame(all_organic_rows, organic_schema)\n",
    "        upsert_table(df_organic, \"silver_all_organic\", [\"platform\", \"post_id\"], schema)\n",
    "        print(\"  Silver organic total: \" + str(len(all_organic_rows)))\n",
    "    \n",
    "    # --- Silver E-commerce ---\n",
    "    # Reads bronze orders, products and customers for each active platform\n",
    "    # and upserts each into its corresponding silver table.\n",
    "    for fuente_id, resources in PARSERS_ECOMMERCE.items():\n",
    "        if not config[\"fuentes\"].get(fuente_id, {}).get(\"activo\", False):\n",
    "            continue\n",
    "        print(\"  --- \" + fuente_id + \" ecommerce ---\")\n",
    "        for resource_name, (bronze_path, parser) in resources.items():\n",
    "            try:\n",
    "                bronze = spark.read.json(\"Files/\" + client_id + \"/bronze/\" + bronze_path)\n",
    "                raw = json.loads(bronze.select(\"raw_data\").collect()[0][0])\n",
    "                if len(raw) > 0:\n",
    "                    rows = parser(raw)\n",
    "                    if resource_name == \"orders\":\n",
    "                        df = spark.createDataFrame(rows, ecommerce_orders_schema)\n",
    "                        upsert_table(df, \"silver_ecommerce_orders\", [\"platform\", \"order_id\"], schema)\n",
    "                    elif resource_name == \"products\":\n",
    "                        df = spark.createDataFrame(rows, ecommerce_products_schema)\n",
    "                        upsert_table(df, \"silver_ecommerce_products\", [\"platform\", \"product_id\"], schema)\n",
    "                    elif resource_name == \"customers\":\n",
    "                        df = spark.createDataFrame(rows, ecommerce_customers_schema)\n",
    "                        upsert_table(df, \"silver_ecommerce_customers\", [\"platform\", \"customer_id\"], schema)\n",
    "                    print(\"  \" + resource_name + \": \" + str(len(rows)) + \" registros\")\n",
    "            except Exception as e:\n",
    "                print(\"  \" + resource_name + \": sin datos (\" + str(e)[:50] + \")\")"
   ],
