    "# Parsers for e-commerce platforms (Shopify, Tiendanube, Emprendtienda, Mercado Libre, Amazon).\n",
    "# Currently only Shopify is implemented.\n",
    "\n",
    "def parse_shopify_orders(raw_data):\n",
    "    \"\"\"\n",
    "    Parses raw Shopify Orders API response into a list of tuples.\n",
    "    Expands each order by line item. If an order has no line items,\n",
    "    inserts a single row with order-level totals.\n",
    "    \"\"\"\n",
    "    rows = []\n",
    "    for o in raw_data:\n",
    "        order_id = str(o.get(\"id\", \"\"))\n",
    "        email = str(o.get(\"email\", \"\"))\n",
    "        created_at = str(o.get(\"created_at\", \"\"))\n",
    "        currency = str(o.get(\"currency\", \"\"))\n",
    "        financial_status = str(o.get(\"financial_status\", \"\"))\n",
    "        fulfillment_status = str(o.get(\"fulfillment_status\", \"\") or \"unfulfilled\")\n",
    "        total_discount = float(o.get(\"total_discounts\", 0))\n",
    "        \n",
    "        line_items = o.get(\"line_items\", [])\n",
    "        \n",
    "        if len(line_items) > 0:\n",
    "            for item in line_items:\n",
    "                rows.append((\n",
    "                    \"shopify\",\n",
    "                    order_id,\n",
    "                    str(item.get(\"product_id\", \"\")),\n",
    "                    str(item.get(\"title\", \"\")),\n",
    "                    email,\n",
    "                    created_at,\n",
    "                    float(item.get(\"price\", 0)),\n",
    "                    float(item.get(\"price\", 0)) * int(item.get(\"quantity\", 1)),\n",
    "                    total_discount,\n",
    "                    currency,\n",
    "                    int(item.get(\"quantity\", 1)),\n",
    "                    financial_status,\n",
    "                    fulfillment_status,\n",
    "                    len(line_items)\n",
    "                ))\n",
    "        else:\n",
    "            rows.append((\n",
    "                \"shopify\",\n",
    "                order_id,\n",
    "                \"\",\n",
    "                \"\",\n",
    "                email,\n",
    "                created_at,\n",
    "                float(o.get(\"total_price\", 0)),\n",
    "                float(o.get(\"total_price\", 0)),\n",
    "                total_discount,\n",
    "                currency,\n",
    "                0,\n",
    "                financial_status,\n",
    "                fulfillment_status,\n",
    "                0\n",
    "            ))\n",
    "    return rows\n",
    "\n",
    "\n",
    "def parse_shopify_products(raw_data):\n",
    "    \"\"\"\n",
    "    Parses raw Shopify Products API response into a list of tuples.\n",
    "    Extracts price and inventory from the first variant.\n",
    "    \"\"\"\n",
    "    rows = []\n",
    "    for p in raw_data:\n",
    "        price = 0.0\n",
    "        inv = 0\n",
    "        variants = p.get(\"variants\", [])\n",
    "        if len(variants) > 0:\n",
    "            price = float(variants[0].get(\"price\", 0))\n",
    "            inv = int(variants[0].get(\"inventory_quantity\", 0))\n",
    "        rows.append((\n",
    "            \"shopify\",\n",
    "            str(p.get(\"id\", \"\")),\n",
    "            str(p.get(\"title\", \"\")),\n",
    "            str(p.get(\"product_type\", \"\")),\n",
    "            str(p.get(\"vendor\", \"\")),\n",
    "            price,\n",
    "            str(p.get(\"status\", \"\")),\n",
    "            inv\n",
    "        ))\n",
    "    return rows\n",
    "\n",
    "\n",
    "def parse_shopify_customers(raw_data):\n",
    "    \"\"\"\n",
    "    Parses raw Shopify Customers API response into a list of tuples\n",
    "    with customer identity, location and purchase summary.\n",
    "    \"\"\"\n",
    "    rows = []\n",
    "    for c in raw_data:\n",
    "        addr = c.get(\"default_address\", {}) or {}\n",
    "        rows.append((\n",
    "            \"shopify\",\n",
    "            str(c.get(\"id\", \"\")),\n",
    "            str(c.get(\"email\", \"\")),\n",
    "            str(c.get(\"first_name\", \"\")),\n",
    "            str(c.get(\"last_name\", \"\")),\n",
    "            str(addr.get(\"city\", \"\")),\n",
    "            str(addr.get(\"country\", \"\")),\n",
    "            int(c.get(\"orders_count\", 0)),\n",
    "            float(c.get(\"total_spent\", 0))\n",
    "        ))\n",
    "    return rows"
   ],
