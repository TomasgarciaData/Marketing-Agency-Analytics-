    "def parse_meta_organic(raw_data):\n",
    "    \"\"\"\n",
    "    Parses enriched Meta organic posts into a list of tuples.\n",
    "    Aggregates likes, love and wow reactions into a single total_reactions field.\n",
    "    \"\"\"\n",
    "    rows = []\n",
    "    for p in raw_data:\n",
    "        total_reactions = int(p.get(\"likes\", 0)) + int(p.get(\"love\", 0)) + int(p.get(\"wow\", 0))\n",
    "        rows.append((\n",
    "            \"meta\",\n",
    "            str(p.get(\"id\", \"\")),\n",
    "            str(p.get(\"message\", \"\")),\n",
    "            str(p.get(\"created_time\", \"\")),\n",
    "            str(p.get(\"permalink_url\", \"\")),\n",
    "            int(p.get(\"shares\", 0)),\n",
    "            total_reactions,\n",
    "            int(p.get(\"comments\", 0)),\n",
    "            int(p.get(\"reach\", 0)),\n",
    "            int(p.get(\"reach\", 0))\n",
    "        ))\n",
    "    return rows\n",
    "\n",
    "\n",
    "# Parsers for review platforms (Yelp, TripAdvisor) — not yet implemented."
